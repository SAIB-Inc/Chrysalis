# Top-level EditorConfig
root = true

[*.cs]

# ── Style preferences ──
csharp_style_namespace_declarations = file_scoped

# ── Expression-body preferences: allow either style ──
csharp_style_expression_bodied_methods = true:silent
csharp_style_expression_bodied_constructors = true:silent
csharp_style_expression_bodied_operators = true:silent
csharp_style_expression_bodied_properties = true:silent
csharp_style_expression_bodied_indexers = true:silent
csharp_style_expression_bodied_accessors = true:silent
csharp_style_expression_bodied_lambdas = true:silent
csharp_style_expression_bodied_local_functions = true:silent
dotnet_diagnostic.IDE0045.severity = suggestion
dotnet_diagnostic.IDE0046.severity = suggestion

# ── Promote ALL Roslyn style suggestions to warnings. ──
# Combined with TreatWarningsAsErrors in Directory.Build.props,
# every IDE suggestion becomes a build error.
dotnet_analyzer_diagnostic.category-Style.severity = warning

# ── Deferred rules (tracked in GitHub issue) ──
# CA1819: byte[] → ReadOnlyMemory<byte> (requires Span/Memory refactoring)
# CA1002: List<T> → IReadOnlyList<T> (tied to code generator)
# CA1724: type/namespace naming conflicts (breaking API change)
# CA1054/CA1056: string → Uri parameters (breaking API change)
# CA1303: string literals in Console output (not applicable for CLI tools)
# CA1515: SUPPRESS — public → internal in applications (conflicts with code generator partial types; revisit later)
dotnet_diagnostic.CA1819.severity = none
dotnet_diagnostic.CA1515.severity = none
dotnet_diagnostic.CA1002.severity = none
dotnet_diagnostic.CA1724.severity = none
dotnet_diagnostic.CA1054.severity = none
dotnet_diagnostic.CA1056.severity = none
dotnet_diagnostic.CA1303.severity = none
dotnet_diagnostic.CA1031.severity = none
# IDE0370: null-forgiving operator — needed for late-initialized properties (set in StartAsync)
dotnet_diagnostic.IDE0370.severity = none
# CA2007: ConfigureAwait — no SynchronizationContext in .NET 6+ ASP.NET Core / console / gRPC consumers
dotnet_diagnostic.CA2007.severity = none

# ── XML documentation ──
dotnet_diagnostic.CS1591.severity = warning

# ── Chrysalis.Plutus: suppress noisy rules for record-heavy code ──
[src/Chrysalis.Plutus/**.cs]
dotnet_diagnostic.CS1591.severity = none
# CA1707: underscores in type names — needed for BLS12-381 / crypto naming consistency
dotnet_diagnostic.CA1707.severity = none
# CA2225: operator alternates — not needed for internal budget arithmetic
dotnet_diagnostic.CA2225.severity = none
# IDE0078: use pattern matching — BigInteger doesn't support constant patterns
dotnet_diagnostic.IDE0078.severity = none

# ── Generated code ──
[*.g.cs]
generated_code = true

# ── Scripts folder: namespace intentionally differs from folder structure ──
[src/Chrysalis.Codec/Types/Cardano/Core/Scripts/**.cs]
dotnet_diagnostic.IDE0130.severity = none

# ── Test projects ──
[src/Chrysalis.Codec.Test/**.cs]
dotnet_diagnostic.CS1591.severity = none
dotnet_diagnostic.CA1707.severity = none
dotnet_diagnostic.CA1812.severity = none
dotnet_diagnostic.CA1852.severity = none
dotnet_diagnostic.IDE0002.severity = none

[src/Chrysalis.Network.Tests/**.cs]
