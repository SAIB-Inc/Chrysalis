# Top-level EditorConfig
root = true

[*.cs]

# ── Style preferences ──
csharp_style_namespace_declarations = file_scoped

# ── Promote ALL Roslyn style suggestions to warnings. ──
# Combined with TreatWarningsAsErrors in Directory.Build.props,
# every IDE suggestion becomes a build error.
dotnet_analyzer_diagnostic.category-Style.severity = warning

# ── Deferred rules (tracked in GitHub issue) ──
# CA1819: byte[] → ReadOnlyMemory<byte> (requires Span/Memory refactoring)
# CA1002: List<T> → IReadOnlyList<T> (tied to code generator)
# CA1724: type/namespace naming conflicts (breaking API change)
# CA1054/CA1056: string → Uri parameters (breaking API change)
# CA1303: string literals in Console output (not applicable for CLI tools)
# CA1515: SUPPRESS — public → internal in applications (conflicts with code generator partial types; revisit later)
dotnet_diagnostic.CA1819.severity = none
dotnet_diagnostic.CA1515.severity = none
dotnet_diagnostic.CA1002.severity = none
dotnet_diagnostic.CA1724.severity = none
dotnet_diagnostic.CA1054.severity = none
dotnet_diagnostic.CA1056.severity = none
dotnet_diagnostic.CA1303.severity = none
dotnet_diagnostic.CA1031.severity = none
# CA2007: ConfigureAwait — no SynchronizationContext in .NET 6+ ASP.NET Core / console / gRPC consumers
dotnet_diagnostic.CA2007.severity = none

# ── XML documentation ──
dotnet_diagnostic.CS1591.severity = warning

# ── Generated code ──
[*.g.cs]
generated_code = true

# ── Test projects ──
[src/Chrysalis.Cbor.Test/**.cs]
dotnet_diagnostic.CS1591.severity = none
dotnet_diagnostic.CA1707.severity = none
dotnet_diagnostic.CA1812.severity = none
dotnet_diagnostic.CA1852.severity = none

[src/Chrysalis.Network.Tests/**.cs]
dotnet_diagnostic.CS1591.severity = none
dotnet_diagnostic.CA1707.severity = none
dotnet_diagnostic.CA1812.severity = none
dotnet_diagnostic.CA1852.severity = none

[src/Chrysalis.Wallet.Test/**.cs]
dotnet_diagnostic.CS1591.severity = none
dotnet_diagnostic.CA1707.severity = none
dotnet_diagnostic.CA1812.severity = none
dotnet_diagnostic.CA1852.severity = none

[src/Chrysalis.Crypto.Test/**.cs]
dotnet_diagnostic.CS1591.severity = none
dotnet_diagnostic.CA1707.severity = none
dotnet_diagnostic.CA1812.severity = none
dotnet_diagnostic.CA1852.severity = none

# ── CLI tools ──
[src/Chrysalis.Tx.Cli/**.cs]
dotnet_diagnostic.CS1591.severity = none
dotnet_diagnostic.CA1849.severity = none

[src/Chrysalis.Network.Cli/**.cs]
dotnet_diagnostic.CS1591.severity = none
dotnet_diagnostic.CA1849.severity = none

[src/Chrysalis.Wallet.Cli/**.cs]
dotnet_diagnostic.CS1591.severity = none
dotnet_diagnostic.CA1849.severity = none

# ── Benchmarks ──
[benchmarks/**.cs]
dotnet_diagnostic.CS1591.severity = none
dotnet_diagnostic.CA1849.severity = none
dotnet_diagnostic.CA1050.severity = none

